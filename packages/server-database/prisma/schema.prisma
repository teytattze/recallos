// One schema = one migration history for the consolidated Aurora cluster
// (events, embeddings, graph edges).
generator client {
  provider        = "prisma-client"
  output          = "../src/generated"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // URL lives in prisma.config.ts (Prisma 7 forbids it here).
  // pgvector — recall is co-located with relational metadata (see decision record).
  extensions = [vector]
}

/// Rows are immutable; updated_at would always equal created_at.
model Event {
  id         String   @id @db.Uuid
  occurredAt DateTime @map("occurred_at") @db.Timestamptz(6)
  createdAt  DateTime @map("created_at") @db.Timestamptz(6)
  tags       Json     @db.JsonB
  body       Json     @db.JsonB

  // Worker drains the log in capture order; routes on tags (e.g. tags @> '{"source":...}').
  @@index([createdAt])
  @@index([tags(ops: JsonbOps)], type: Gin)
  @@map("events")
}

enum EventOutboxStatus {
  pending
  sent

  @@map("event_outbox_status")
}

/// Transactional outbox (see outbox decision record): one row written in the same
/// transaction as the events insert, so "recorded" and "will be published" are a
/// single atomic fact. A relay drains pending rows to SQS and marks them sent.
/// Metadata-only by design. The relay joins `events` to publish the canonical body
/// in SQS without duplicating it in the outbox table.
model EventOutbox {
  id         String            @id @default(uuid(7)) @db.Uuid
  eventId    String            @map("event_id") @db.Uuid
  occurredAt DateTime          @map("occurred_at") @db.Timestamptz(6)
  createdAt  DateTime          @map("created_at") @db.Timestamptz(6)
  tags       Json              @db.JsonB
  status     EventOutboxStatus @default(pending)
  queuedAt   DateTime          @default(now()) @map("queued_at") @db.Timestamptz(6)
  sentAt     DateTime?         @map("sent_at") @db.Timestamptz(6)

  // Relay claims pending rows in capture order (FOR UPDATE SKIP LOCKED).
  @@index([status, queuedAt])
  @@map("event_outbox")
}
