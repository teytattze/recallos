// One schema = one migration history for the consolidated Aurora cluster
// (events, embeddings, graph edges).
generator client {
  provider        = "prisma-client"
  output          = "../src/generated"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  // URL lives in prisma.config.ts (Prisma 7 forbids it here).
  // pgvector — recall is co-located with relational metadata (see decision record).
  extensions = [vector]
}
