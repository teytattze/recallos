{
  "name": "recallos",
  "private": true,
  "workspaces": [
    "apps/*",
    "infrastructure",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "db:generate": "bun run --filter @repo/server-database db:generate",
    "db:migrate:deploy": "bun run --filter @repo/server-database db:migrate:deploy",
    "db:migrate:dev": "bun run --filter @repo/server-database db:migrate:dev",
    "db:migrate:reset": "bun run --filter @repo/server-database db:migrate:reset",
    "db:studio": "bun run --filter @repo/server-database db:studio",
    "dev": "turbo run dev",
    "fmt": "oxfmt",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "bun@1.3.14",
